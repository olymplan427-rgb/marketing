# Google Gemini API Configuration
# API 키는 보안상 환경변수가 아닌 UI의 'AI 설정' 메뉴에서 입력하세요.
# API 키 발급: https://aistudio.google.com/app/apikey

# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Threads API Configuration
VITE_THREADS_APP_ID=your_threads_app_id
VITE_THREADS_APP_SECRET=your_threads_app_secret
# 로컬 개발용
VITE_THREADS_REDIRECT_URI=http://localhost:5173/auth/threads/callback
# 프로덕션용 (Vercel) - 배포 후 실제 도메인으로 교체
# VITE_THREADS_REDIRECT_URI=https://<your-project>.vercel.app/auth/threads/callback

# Production URL (서버리스 API의 CORS 허용 도메인)
# Vercel 배포 시 VERCEL_PROJECT_PRODUCTION_URL이 자동 설정되므로 보통 생략 가능.
# 커스텀 도메인 등 직접 지정이 필요할 때만 설정.
# PRODUCTION_URL=https://<your-project>.vercel.app

# Development Environment
VITE_APP_TITLE=AI Blog Post Generator
VITE_APP_VERSION=1.0.0